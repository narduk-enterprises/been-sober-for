@narduk-enterprises:registry=https://npm.pkg.github.com
; Token from env (no secret committed). Local: ~/.npmrc can still add a literal token if you prefer.
; CI / agents: export NODE_AUTH_TOKEN (GitHub Packages read PAT). Doppler `prd_copilot` + sync:copilot-secrets.
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

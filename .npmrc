@narduk-enterprises:registry=https://npm.pkg.github.com
; Token from env (no secret committed). Doppler: GITHUB_TOKEN_PACKAGES_READ → sync:copilot-secrets sets NODE_AUTH_TOKEN on GitHub.
; Local: doppler run -- pnpm install, or ~/.npmrc with a token.
//npm.pkg.github.com/:_authToken=${NODE_AUTH_TOKEN}

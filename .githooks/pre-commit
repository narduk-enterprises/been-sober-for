#!/bin/sh
#
# Pre-commit hook. Runs two independent guards before allowing a commit:
#
#   1. Prettier auto-format pass on staged formattable files. Runs
#      `prettier --write` (via narduk-starter-toolkit format-staged-files,
#      fallback tools/format-staged-files.cjs) so the hook actively fixes
#      editor-formatter drift (e.g. Cursor/VS Code's built-in HTML
#      formatter collapsing multi-attribute Vue tags) and restages the
#      formatted files. Prettier respects .prettierignore, so generated
#      trees are skipped automatically.
#   2. Lockfile parity: pnpm-lock.yaml must be updated when dependency-related
#      fields in package.json or dependency-affecting lines in .npmrc change.
#      Script-only edits (e.g. changing a "scripts" entry) do NOT require a
#      lockfile update.
#
# Escape hatch for rescue commits on a broken tree:
#   SKIP_PRETTIER_HOOK=1 git commit -m "rescue: ..."
# The lockfile guard and the .npmrc.auth guard cannot be bypassed.
#
# Install: git config core.hooksPath .githooks
# This hook is synced into fleet apps through the starter export flow.

ROOT_DIR=$(git rev-parse --show-toplevel 2>/dev/null || pwd)
cd "$ROOT_DIR"

# ── Prettier auto-format pass on staged formattable files ───────────────
# Delegates to the starter toolkit (or the vendored fallback formatter) so
# the same formatter runs in the editor, the hook, and CI. The toolkit
# stashes unstaged edits, runs `prettier --write`, restages, then restores.
# This is a mutating pass, not a read-only check.
if [ -z "$SKIP_PRETTIER_HOOK" ]; then
  if [ -x "$ROOT_DIR/node_modules/.bin/narduk-starter-toolkit" ] || [ -x "$ROOT_DIR/node_modules/.bin/narduk-starter-toolkit.cmd" ]; then
    pnpm exec narduk-starter-toolkit format-staged-files || exit 1
  elif [ -f "$ROOT_DIR/tools/format-staged-files.cjs" ]; then
    node tools/format-staged-files.cjs || exit 1
  else
    echo ""
    echo "Skipping staged-file formatting until the starter toolkit or legacy formatter has been installed."
    echo ""
  fi
fi

STAGED=$(git diff --cached --name-only)

if echo "$STAGED" | grep -qE '(^|/)\.npmrc\.auth$'; then
  echo ""
  echo ".npmrc.auth is generated from package-registry auth and must not be committed."
  echo "Remove it from the index with: git restore --staged .npmrc.auth"
  echo ""
  exit 1
fi

# Check if .npmrc changed in a way that can alter dependency resolution.
NPMRC_FILES=$(echo "$STAGED" | grep -E '(^|/)\.npmrc$' || true)

# Check if any package.json changed
PKG_FILES=$(echo "$STAGED" | grep -E '(^|\/)package\.json$' || true)

NPMRC_CHANGED=""
if [ -n "$NPMRC_FILES" ]; then
  for f in $NPMRC_FILES; do
    if git diff --cached -U0 "$f" 2>/dev/null \
      | grep -E '^[+-]' \
      | grep -vE '^(\+\+\+|---)' \
      | grep -vE '^[+-]//[^[:space:]]+:_authToken=' \
      | grep -vE '^[+-]; Auth token injected via CI env$' \
      | grep -q '.'; then
      NPMRC_CHANGED="yes"
      break
    fi
  done
fi

# For package.json, only flag if dependency-related fields actually changed
DEP_CHANGED=""
if [ -n "$PKG_FILES" ]; then
  for f in $PKG_FILES; do
    # Check if the diff touches dependency-related keys
    if git diff --cached -U0 "$f" 2>/dev/null | grep -qE '"(dependencies|devDependencies|peerDependencies|optionalDependencies|pnpm|overrides|resolutions|packageManager)"'; then
      DEP_CHANGED="yes"
      break
    fi
  done
fi

if [ -n "$DEP_CHANGED" ] || [ -n "$NPMRC_CHANGED" ]; then
  LOCK_CHANGED=$(echo "$STAGED" | grep 'pnpm-lock.yaml' || true)
  if [ -z "$LOCK_CHANGED" ]; then
    echo ""
    echo "Lockfile drift detected."
    echo ""
    echo "Dependency fields in package.json or .npmrc changed but pnpm-lock.yaml was not updated."
    echo "Run: pnpm install --no-frozen-lockfile"
    echo "Then: git add pnpm-lock.yaml"
    echo ""
    exit 1
  fi
fi
